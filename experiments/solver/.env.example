# LLM-Guided SAT Solver — API Keys
# Copy this file to .env and fill in at least one key.
# Priority order: GitHub Models → Gemini → OpenAI

# GitHub Models (gpt-4o-mini) — free with any GitHub account
# Get token at: https://github.com/settings/tokens (no scopes needed for Models API)
GITHUB_TOKEN=github_pat_...

# Google Gemini (gemini-3.1-flash-lite-preview) — free tier available
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AI...

# OpenAI — paid, no free tier
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
